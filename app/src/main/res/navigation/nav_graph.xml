<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.project.habittracker.view.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"/>
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.project.habittracker.view.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">

        <action
            android:id="@+id/action_dashboard_to_create"
            app:destination="@id/createHabitFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/createHabitFragment"
        android:name="com.project.habittracker.view.CreateHabitFragment"
        android:label="Create Habit"
        tools:layout="@layout/fragment_create_habit" />

</navigation>